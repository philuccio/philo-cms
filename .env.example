# ── Database MySQL ─────────────────────────────────────────────────────────────
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/philo_cms"

# ── NextAuth.js ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera con: openssl rand -base64 32"

# ── Revalidazione ISR ──────────────────────────────────────────────────────────
REVALIDATE_SECRET="stringa casuale sicura"

# ── Media Storage (scegli uno) ─────────────────────────────────────────────────
# Opzione A — Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Opzione B — AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-south-1"
AWS_S3_BUCKET="philo-media"
AWS_CLOUDFRONT_URL=""

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@tuodominio.it"
EMAIL_TO="admin@tuodominio.it"

# ── Google Fonts API (Theme Builder) ──────────────────────────────────────────
GOOGLE_FONTS_API_KEY=""

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_ID=""

# ── Sentry (opzionale — fase 04) ──────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
