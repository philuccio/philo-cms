{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "plugins": [{ "name": "next" }],
    "jsx": "preserve",
    "incremental": true,
    "noEmit": true
  },
  "include": ["src", "next-env.d.ts", "next.config.ts", "*.ts", "*.tsx"],
  "exclude": ["node_modules"]
}
